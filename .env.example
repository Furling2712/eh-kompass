# Mitarbeiter-Passwort-Hash (nicht das Passwort selbst!).
# Erzeugen mit: npm run staff:hash -- "DeinPasswort"
STAFF_PASSWORD_HASH=

# Geheimer Schlüssel zum Signieren der Login-Sitzung.
# Einmalig erzeugen mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STAFF_SESSION_SECRET=
