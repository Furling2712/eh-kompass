# Mitarbeiter-Passwort-Hash (nicht das Passwort selbst!).
# Erzeugen mit: npm run staff:hash -- "DeinPasswort"
STAFF_PASSWORD_HASH=

# Geheimer Schlüssel zum Signieren der Mitarbeiter-Login-Sitzung.
# Einmalig erzeugen mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STAFF_SESSION_SECRET=

# Zugangscode-Hash für die Online-BeWo-Video-Sprechstunde (nicht der Code selbst!).
# Erzeugen mit: npm run bewo:hash -- "DeinZugangscode"
CLIENT_PASSWORD_HASH=

# Geheimer Schlüssel zum Signieren der Klienten-Login-Sitzung. Bewusst getrennt von
# STAFF_SESSION_SECRET, damit ein Klienten-Code niemals eine Mitarbeiter-Sitzung fälschen kann.
# Einmalig erzeugen mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLIENT_SESSION_SECRET=
