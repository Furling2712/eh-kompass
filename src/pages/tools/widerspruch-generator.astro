---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Disclaimer from '../../components/Disclaimer.astro';

// Generische Begründungsbausteine. Bewusst allgemein gehalten (keine Einzelfall-/Erfolgsprognose, RDG).
const bausteine = [
  {
    id: 'hoehe',
    label: 'Der bewilligte Umfang / die Höhe der Leistung erscheint mir zu gering.',
  },
  {
    id: 'ablehnung',
    label: 'Die Leistung wurde ganz oder teilweise abgelehnt.',
  },
  {
    id: 'bedarf',
    label: 'Mein tatsächlicher Bedarf wurde aus meiner Sicht nicht vollständig berücksichtigt.',
  },
  {
    id: 'begruendung',
    label: 'Die Begründung des Bescheids ist für mich nicht nachvollziehbar.',
  },
  {
    id: 'anhoerung',
    label: 'Ich hatte keine ausreichende Gelegenheit, meine Sicht darzustellen.',
  },
];
---

<BaseLayout
  title="Muster-Widerspruch-Generator"
  description="Erstelle aus Textbausteinen einen anpassbaren Entwurf für dein Widerspruchsschreiben gegen einen Eingliederungshilfe-Bescheid. Kein Ersatz für Rechtsberatung."
>
  <div class="container prose article">
    <span class="badge">Tool · Vorlage</span>
    <h1>Muster-Widerspruch-Generator</h1>
    <p class="lead muted">
      Dieses Tool stellt aus Textbausteinen einen <strong>Entwurf</strong> für dein
      Widerspruchsschreiben zusammen. Du kannst ihn frei anpassen, kopieren oder herunterladen und
      reichst ihn selbst bei der Behörde ein.
    </p>

    <div class="notice">
      <strong>Kein Ersatz für Rechtsberatung</strong>
      <p style="margin-bottom:0">
        Der Generator kombiniert nur allgemeine Formulierungen – wie ein Musterbrief in einem
        Ratgeber. Er nimmt <strong>keine</strong> rechtliche Bewertung deines Einzelfalls vor und
        gibt keine Erfolgsprognose ab. Für eine inhaltliche Prüfung wende dich an eine
        Sozialberatung, einen Sozialverband (VdK/SoVD) oder einen Fachanwalt für Sozialrecht.
      </p>
    </div>

    <div class="tool-box">
      <form id="wg-form">
        <h3 style="margin-top:0">1. Deine Angaben</h3>
        <div class="field">
          <label for="name">Dein Name</label>
          <input type="text" id="name" placeholder="Vor- und Nachname" />
        </div>
        <div class="field">
          <label for="strasse">Straße und Hausnummer</label>
          <input type="text" id="strasse" placeholder="Musterstraße 1" />
        </div>
        <div class="grid2 grid2-plz">
          <div class="field">
            <label for="plz">PLZ</label>
            <input type="text" id="plz" placeholder="12345" inputmode="numeric" />
          </div>
          <div class="field">
            <label for="ort">Ort</label>
            <input type="text" id="ort" placeholder="Musterstadt" />
          </div>
        </div>

        <h3>2. Angaben zum Bescheid</h3>
        <div class="field">
          <label for="behoerde">Behörde / Kostenträger</label>
          <input type="text" id="behoerde" placeholder="z. B. LVR / Bezirksregierung / Kreis …" />
        </div>
        <div class="field">
          <label for="behoerde-strasse">Straße und Hausnummer der Behörde</label>
          <input type="text" id="behoerde-strasse" placeholder="Musterallee 1" />
        </div>
        <div class="grid2 grid2-plz">
          <div class="field">
            <label for="behoerde-plz">PLZ</label>
            <input type="text" id="behoerde-plz" placeholder="54321" inputmode="numeric" />
          </div>
          <div class="field">
            <label for="behoerde-ort">Ort</label>
            <input type="text" id="behoerde-ort" placeholder="Musterstadt" />
          </div>
        </div>
        <div class="grid2">
          <div class="field">
            <label for="az">Aktenzeichen / Geschäftszeichen</label>
            <input type="text" id="az" placeholder="steht oben auf dem Bescheid" />
          </div>
          <div class="field">
            <label for="bescheiddatum">Datum des Bescheids</label>
            <input type="date" id="bescheiddatum" />
          </div>
        </div>

        <h3>3. Worum geht es?</h3>
        <p class="small muted" style="margin-top:0">Wähle aus, was auf dich zutrifft (Mehrfachauswahl möglich).</p>
        {
          bausteine.map((b) => (
            <label class="check">
              <input type="checkbox" value={b.id} data-baustein />
              <span>{b.label}</span>
            </label>
          ))
        }

        <div class="field" style="margin-top:1.1rem">
          <label for="eigenerText">Eigene Ergänzung (optional)</label>
          <textarea
            id="eigenerText"
            rows="4"
            placeholder="Beschreibe in eigenen Worten, warum du mit dem Bescheid nicht einverstanden bist. Konkrete Beispiele aus deinem Alltag helfen."
          ></textarea>
        </div>

        <div class="field">
          <label class="check">
            <input type="checkbox" id="begruendungNachreichen" />
            <span>Ich möchte die ausführliche Begründung später nachreichen.</span>
          </label>
        </div>

        <button type="submit" class="btn">Entwurf erstellen</button>
      </form>
    </div>

    <div id="wg-output-wrap" hidden>
      <h2>Dein Entwurf</h2>
      <p class="small muted">
        Prüfe und ergänze den Text, bevor du ihn verschickst. Alles in eckigen Klammern
        <code>[…]</code> solltest du noch ausfüllen oder anpassen.
      </p>
      <div class="output-actions">
        <button type="button" id="copyBtn" class="btn btn-secondary">In Zwischenablage kopieren</button>
        <button type="button" id="pdfBtn" class="btn btn-secondary">Als PDF herunterladen</button>
        <button type="button" id="docxBtn" class="btn btn-secondary">Als Word (.docx) herunterladen</button>
        <button type="button" id="odtBtn" class="btn btn-secondary">Als OpenDocument (.odt) herunterladen</button>
        <span id="copyStatus" class="small" aria-live="polite"></span>
      </div>
      <p class="small muted" style="margin:0 0 .75rem">
        Das .odt-Format öffnet sich direkt in LibreOffice und Apache OpenOffice.
      </p>
      <div class="output-page-wrap">
        <textarea id="wg-output" class="output-page" spellcheck="false"></textarea>
      </div>
    </div>

    <h2>Nach dem Erstellen: so geht es weiter</h2>
    <ul>
      <li>Widerspruch möglichst <strong>schriftlich</strong> und fristgerecht einreichen (<a href="/tools/fristenrechner">Frist prüfen</a>).</li>
      <li>Unterschreiben nicht vergessen. Versand am besten nachweisbar (z. B. Einwurf-Einschreiben).</li>
      <li>Eine Kopie für deine Unterlagen behalten.</li>
      <li>Eine ausführliche Begründung kannst du auch später nachreichen – kündige das im Schreiben an.</li>
    </ul>

    <Disclaimer
      stand="Juli 2026"
      quelle="https://www.gesetze-im-internet.de/sgg/__84.html"
      quelleLabel="§ 84 SGG"
    />
  </div>
</BaseLayout>

<style>
  .article {
    padding-block: 2.5rem 1rem;
  }
  .grid2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .grid2-plz {
    grid-template-columns: 8rem 1fr;
  }
  .check {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-weight: 400;
    margin-bottom: 0.6rem;
    cursor: pointer;
  }
  .check input {
    width: auto;
    margin-top: 0.3rem;
    flex: 0 0 auto;
  }
  .output-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .output-page-wrap {
    display: flex;
    justify-content: center;
    background: var(--color-accent);
    padding: 2rem 1rem;
    border-radius: var(--radius);
  }
  .output-page {
    width: 100%;
    max-width: 21cm;
    aspect-ratio: 210 / 297;
    background: #fff;
    color: #1a1a1a;
    border: 1px solid var(--color-border);
    box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.15);
    padding: 2.5cm 2cm;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 0.95rem;
    line-height: 1.5;
    resize: vertical;
  }
  @media (max-width: 600px) {
    .grid2 {
      grid-template-columns: 1fr;
    }
    .grid2-plz {
      grid-template-columns: 1fr;
    }
    .output-page {
      aspect-ratio: auto;
      padding: 1.25rem;
    }
  }
</style>

<script>
  import { jsPDF } from 'jspdf';
  import { Document, Packer, Paragraph, TextRun } from 'docx';
  import JSZip from 'jszip';

  const bausteinTexte: Record<string, string> = {
    hoehe:
      'Der mit dem Bescheid bewilligte Umfang der Leistung entspricht aus meiner Sicht nicht meinem tatsächlichen Unterstützungsbedarf.',
    ablehnung:
      'Die von mir beantragte Leistung wurde ganz oder teilweise abgelehnt. Damit bin ich nicht einverstanden.',
    bedarf:
      'Mein tatsächlicher Bedarf wurde aus meiner Sicht im Verfahren nicht vollständig erfasst bzw. berücksichtigt.',
    begruendung:
      'Die Begründung des Bescheids ist für mich nicht nachvollziehbar. Ich bitte um eine verständliche Darstellung der Entscheidungsgründe.',
    anhoerung:
      'Ich hatte aus meiner Sicht keine ausreichende Gelegenheit, meine persönliche Situation und meinen Bedarf darzustellen.',
  };

  const form = document.getElementById('wg-form') as HTMLFormElement;
  const outWrap = document.getElementById('wg-output-wrap') as HTMLDivElement;
  const outArea = document.getElementById('wg-output') as HTMLTextAreaElement;
  const val = (id: string) => (document.getElementById(id) as HTMLInputElement)?.value.trim();

  const fmtDate = (v: string) => {
    if (!v) return '[Datum des Bescheids]';
    const [y, m, d] = v.split('-');
    return `${d}.${m}.${y}`;
  };

  function todayLong(): string {
    // Erlaubt: Anzeige des heutigen Datums in der Unterschriftzeile.
    return new Intl.DateTimeFormat('de-DE', {
      day: '2-digit',
      month: 'long',
      year: 'numeric',
    }).format(new Date());
  }

  // Anschrift nach DIN 5008: Name / Straße Hausnummer / PLZ Ort - jeweils eigene Zeile.
  function anschriftZeilen(namePrefix: string, strasseId: string, plzId: string, ortId: string): string {
    const strasse = val(strasseId) || '[Straße und Hausnummer]';
    const plz = val(plzId);
    const ort = val(ortId);
    const plzOrt = plz || ort ? `${plz || '[PLZ]'} ${ort || '[Ort]'}` : '[PLZ Ort]';
    return `${namePrefix}\n${strasse}\n${plzOrt}`;
  }

  function build(): string {
    const name = val('name') || '[Dein Name]';
    const behoerde = val('behoerde') || '[Behörde / Kostenträger]';
    const az = val('az') || '[Aktenzeichen]';
    const bescheiddatum = fmtDate(val('bescheiddatum'));
    const ort = val('ort') || '[Ort]';
    const eigener = val('eigenerText');
    const nachreichen = (document.getElementById('begruendungNachreichen') as HTMLInputElement).checked;

    const absender = anschriftZeilen(name, 'strasse', 'plz', 'ort');
    const empfaenger = anschriftZeilen(behoerde, 'behoerde-strasse', 'behoerde-plz', 'behoerde-ort');

    const gewaehlt = Array.from(
      form.querySelectorAll<HTMLInputElement>('input[data-baustein]:checked')
    ).map((c) => bausteinTexte[c.value]);

    const gruende =
      gewaehlt.length > 0
        ? gewaehlt.map((g) => `- ${g}`).join('\n')
        : '- [Bitte hier ergänzen, warum du mit dem Bescheid nicht einverstanden bist.]';

    const eigenerBlock = eigener ? `\n\n${eigener}` : '';

    const begruendungSchluss = nachreichen
      ? 'Eine ausführliche Begründung meines Widerspruchs werde ich zeitnah nachreichen.'
      : 'Ich bitte um erneute Prüfung und um einen entsprechend abgeänderten Bescheid.';

    return `${absender}


${empfaenger}


${ort}, den ${todayLong()}


Widerspruch gegen den Bescheid vom ${bescheiddatum}
Aktenzeichen: ${az}


Sehr geehrte Damen und Herren,

gegen den oben genannten Bescheid vom ${bescheiddatum} lege ich hiermit fristgerecht

                                   W i d e r s p r u c h

ein.

Ich bin mit der Entscheidung aus folgenden Gründen nicht einverstanden:

${gruende}${eigenerBlock}

${begruendungSchluss}

Ich bitte um eine schriftliche Eingangsbestätigung.


Mit freundlichen Grüßen




_______________________
${name}`;
  }

  function currentFilename(ext: string): string {
    const name = val('name');
    const slug = name ? name.toLowerCase().replace(/[^a-z0-9äöüß]+/gi, '-').replace(/^-+|-+$/g, '') : 'entwurf';
    return `widerspruch-${slug || 'entwurf'}.${ext}`;
  }

  function downloadBlob(blob: Blob, filename: string) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  }

  function buildPdf(text: string): Blob {
    const doc = new jsPDF({ unit: 'mm', format: 'a4' });
    const marginLeft = 25;
    const marginRight = 20;
    const maxWidth = 210 - marginLeft - marginRight;
    const lineHeight = 5.2;
    const pageBottom = 275;
    doc.setFont('times', 'normal');
    doc.setFontSize(11);

    let y = 25;
    for (const rawLine of text.split('\n')) {
      const wrapped: string[] = rawLine.trim().length
        ? doc.splitTextToSize(rawLine, maxWidth)
        : [''];
      for (const line of wrapped) {
        if (y > pageBottom) {
          doc.addPage();
          y = 25;
        }
        if (line) doc.text(line, marginLeft, y);
        y += lineHeight;
      }
    }
    return doc.output('blob');
  }

  async function buildDocx(text: string): Promise<Blob> {
    const doc = new Document({
      sections: [
        {
          properties: {},
          children: text.split('\n').map(
            (line) =>
              new Paragraph({
                children: [new TextRun({ text: line, font: 'Times New Roman', size: 22 })],
                spacing: { after: 0 },
              })
          ),
        },
      ],
    });
    return Packer.toBlob(doc);
  }

  function xmlEscape(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  async function buildOdt(text: string): Promise<Blob> {
    const paragraphs = text
      .split('\n')
      .map((line) => (line.trim().length ? `<text:p>${xmlEscape(line)}</text:p>` : '<text:p/>'))
      .join('\n');

    const contentXml = `<?xml version="1.0" encoding="UTF-8"?>
<office:document-content xmlns:office="urn:oasis:names:tc:opendocument:xmlns:office:1.0" xmlns:text="urn:oasis:names:tc:opendocument:xmlns:text:1.0" office:version="1.2">
  <office:body>
    <office:text>
${paragraphs}
    </office:text>
  </office:body>
</office:document-content>`;

    const stylesXml = `<?xml version="1.0" encoding="UTF-8"?>
<office:document-styles xmlns:office="urn:oasis:names:tc:opendocument:xmlns:office:1.0" xmlns:style="urn:oasis:names:tc:opendocument:xmlns:style:1.0" xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0" office:version="1.2">
  <office:styles>
    <style:default-style style:family="paragraph">
      <style:text-properties style:font-name="Liberation Serif" fo:font-size="11pt"/>
    </style:default-style>
  </office:styles>
</office:document-styles>`;

    const manifestXml = `<?xml version="1.0" encoding="UTF-8"?>
<manifest:manifest xmlns:manifest="urn:oasis:names:tc:opendocument:xmlns:manifest:1.0" manifest:version="1.2">
  <manifest:file-entry manifest:full-path="/" manifest:version="1.2" manifest:media-type="application/vnd.oasis.opendocument.text"/>
  <manifest:file-entry manifest:full-path="content.xml" manifest:media-type="text/xml"/>
  <manifest:file-entry manifest:full-path="styles.xml" manifest:media-type="text/xml"/>
</manifest:manifest>`;

    const zip = new JSZip();
    zip.file('mimetype', 'application/vnd.oasis.opendocument.text', { compression: 'STORE' });
    zip.file('META-INF/manifest.xml', manifestXml);
    zip.file('content.xml', contentXml);
    zip.file('styles.xml', stylesXml);

    return zip.generateAsync({ type: 'blob', mimeType: 'application/vnd.oasis.opendocument.text' });
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    outArea.value = build();
    outWrap.hidden = false;
    outWrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  const status = document.getElementById('copyStatus') as HTMLSpanElement;

  document.getElementById('copyBtn')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(outArea.value);
      status.textContent = '✓ Kopiert';
    } catch {
      outArea.select();
      status.textContent = 'Bitte mit Strg+C kopieren';
    }
    setTimeout(() => (status.textContent = ''), 2500);
  });

  document.getElementById('pdfBtn')?.addEventListener('click', () => {
    downloadBlob(buildPdf(outArea.value), currentFilename('pdf'));
  });

  document.getElementById('docxBtn')?.addEventListener('click', async () => {
    downloadBlob(await buildDocx(outArea.value), currentFilename('docx'));
  });

  document.getElementById('odtBtn')?.addEventListener('click', async () => {
    downloadBlob(await buildOdt(outArea.value), currentFilename('odt'));
  });
</script>
