---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const terms = (await getCollection('glossar', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.term.localeCompare(b.data.term, 'de')
);
---

<BaseLayout
  title="Glossar"
  description="Wichtige Begriffe und Abkürzungen der Eingliederungshilfe verständlich erklärt: ICF, BEI, PerSEH, Regelbedarf und mehr."
>
  <div class="container prose article">
    <h1>Glossar</h1>
    <p class="lead muted">
      Die wichtigsten Begriffe und Abkürzungen rund um die Eingliederungshilfe – kurz und
      verständlich erklärt.
    </p>
  </div>

  <div class="container">
    {
      terms.length === 0 ? (
        <p class="muted">Noch keine Begriffe veröffentlicht.</p>
      ) : (
        <dl class="glossar-list">
          {terms.map((t) => (
            <div class="glossar-item">
              <dt>
                <a href={`/glossar/${t.id}/`}>{t.data.term}</a>
              </dt>
              <dd>{t.data.description}</dd>
            </div>
          ))}
        </dl>
      )
    }
  </div>
</BaseLayout>

<style>
  .article {
    padding-block: 2.5rem 0.5rem;
  }
  .glossar-list {
    display: grid;
    gap: 1rem;
    margin: 1.5rem 0;
    max-width: var(--readw);
  }
  .glossar-item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    background: #fff;
  }
  dt {
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  dt a {
    text-decoration: none;
  }
  dd {
    margin: 0;
    color: var(--color-muted);
  }
</style>
