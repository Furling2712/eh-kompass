---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('ratgeber', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title="Ratgeber"
  description="Verständliche Artikel rund um Antrag, Bescheid, Bedarfsermittlung und Hilfeplanung in der Eingliederungshilfe."
>
  <div class="container prose article">
    <h1>Ratgeber</h1>
    <p class="lead muted">
      Schritt-für-Schritt-Erklärungen zur Eingliederungshilfe – vom Antrag über den Bescheid bis
      zur Hilfeplanung.
    </p>
  </div>

  <div class="container">
    {
      articles.length === 0 ? (
        <p class="muted">Noch keine Artikel veröffentlicht.</p>
      ) : (
        <ul class="card-grid">
          {articles.map((a) => (
            <li class="card">
              <h3>
                <a href={`/ratgeber/${a.id}/`} class="card-link">
                  {a.data.title}
                </a>
              </h3>
              <p>{a.data.description}</p>
              <a href={`/ratgeber/${a.id}/`} class="small">
                Weiterlesen →
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>

<style>
  .article {
    padding-block: 2.5rem 0.5rem;
  }
</style>
