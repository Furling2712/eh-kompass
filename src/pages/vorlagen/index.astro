---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Checkout-Link vor Launch durch echten Gumroad-/Lemonsqueezy-Link ersetzen.
// Nach erfolgreichem Kauf beim Zahlungsdienstleister als Redirect-/Bestätigungs-URL
// /vorlagen/bei-formular/ hinterlegen (dort liegt das eigentliche Formular).
const CHECKOUT_URL = '#';

const inhalte = [
  'Digitales BEI-Formular: alle Fragen aus der Bedarfsermittlung in Ruhe online beantworten',
  'Exakt dieselben Fragen wie im echten Verfahren – Persönliche Sicht, Ziele, Wohnsituation',
  'Deine Antworten als Datei zum Mitnehmen ins Gespräch oder Weiterleiten an deine Betreuung',
  'Wir übernehmen die Übertragung in dein BEI mit KI-gestützter Formulierung',
];
---

<BaseLayout
  title="BEI-Generierung"
  description="Schreibe deinen BEI in wenigen Minuten statt Stunden: BEI-Formular in Ruhe online ausfüllen, wir übernehmen die KI-gestützte Übertragung in dein Bedarfsermittlungsinstrument."
>
  <div class="container prose article">
    <span class="badge">Digitalprodukt</span>
    <h1>BEI-Generierung</h1>
    <p class="lead muted">
      Schreib deinen BEI in wenigen Minuten – durch KI-gestütztes Ausfüllen mit Hilfe des
      BEI-Formulars. Statt stundenlang im Termin zu grübeln, beantwortest du die Fragen vorher in
      Ruhe zuhause.
    </p>

    <div class="notice">
      <strong>⚠️ Vor Launch einrichten</strong>
      <p style="margin-bottom:0">
        Lege das Produkt bei Gumroad oder Lemonsqueezy an und trage den Checkout-Link in
        <code>src/pages/vorlagen/index.astro</code> (Variable <code>CHECKOUT_URL</code>) ein. Als
        Redirect nach erfolgreichem Kauf <code>/vorlagen/bei-formular/</code> hinterlegen. Passe
        den Preis an dein reales Angebot an.
      </p>
    </div>

    <div class="product">
      <div class="product-info">
        <h2 style="margin-top:0">Was ist enthalten?</h2>
        <ul>
          {inhalte.map((i) => <li>{i}</li>)}
        </ul>
        <p class="small muted">
          Format: Online-Formular · Ergebnis als Datei zum Download · Für den privaten Gebrauch.
        </p>
      </div>

      <aside class="product-buy">
        <p class="price">
          9,90 € <span class="small muted">einmalig</span>
        </p>
        <a href={CHECKOUT_URL} class="btn" style="width:100%;text-align:center">
          Jetzt kaufen
        </a>
        <p class="small muted" style="margin:.75rem 0 0">
          Sichere Abwicklung über einen externen Zahlungsdienstleister.
        </p>
      </aside>
    </div>

    <h2>Für wen ist das gedacht?</h2>
    <p>
      Für Betroffene und Angehörige, die vor einer Bedarfsermittlung stehen und ihre Antworten
      lieber in Ruhe zuhause durchdenken als spontan im Termin. Die Fragen entsprechen dem
      tatsächlichen BEI-Verfahren – kein Rätselraten, was gefragt wird.
    </p>

    <div class="notice">
      <strong>Hinweis zum Datenschutz</strong>
      <p style="margin-bottom:0">
        Deine Angaben im Formular werden ausschließlich in deinem Browser verarbeitet und landen
        nur in der Datei, die du selbst herunterlädst – es erfolgt keine automatische Übertragung
        an uns oder Dritte.
      </p>
    </div>

    <div class="notice">
      <strong>Hinweis</strong>
      <p style="margin-bottom:0">
        Das Formular ist ein Hilfsmittel zur Vorbereitung und ersetzt keine individuelle Beratung.
        Die endgültige Bedarfsermittlung erfolgt immer durch den zuständigen Kostenträger.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .article {
    padding-block: 2.5rem 1rem;
  }
  .product {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 2rem;
    align-items: start;
    margin: 1.5rem 0;
  }
  .product-buy {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    position: sticky;
    top: 5rem;
  }
  .price {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    margin: 0 0 1rem;
  }
  @media (max-width: 700px) {
    .product {
      grid-template-columns: 1fr;
    }
    .product-buy {
      position: static;
    }
  }
</style>
