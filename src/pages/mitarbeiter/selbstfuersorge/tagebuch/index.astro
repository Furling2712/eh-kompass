---
export const prerender = false;

import BaseLayout from '../../../../layouts/BaseLayout.astro';

const prompts = [
  'Was ist mir heute gut gelungen?',
  'Was hat mich heute besonders gefordert oder belastet?',
  'Wofür bin ich heute dankbar?',
  'Was nehme ich mir für morgen vor?',
];
---

<BaseLayout title="Reflexions-Tagebuch" noindex>
  <div class="container prose article">
    <h1>Reflexions-Tagebuch</h1>
    <p class="lead muted">Kurz innehalten und den Tag oder einen Kontakt für dich reflektieren.</p>

    <div class="notice">
      <strong>Nur für dich, nur in diesem Browser</strong>
      <p style="margin-bottom:0">
        Deine Einträge werden ausschließlich lokal in diesem Browser gespeichert (localStorage) –
        es gibt keine Server-Speicherung, niemand sonst kann sie sehen. Das bedeutet aber auch:
        auf einem anderen Gerät/Browser oder nach dem Leeren der Browserdaten sind sie weg. Bitte
        keine Namen oder Details eintragen, die Klienten identifizierbar machen.
      </p>
    </div>

    <div class="tool-box">
      <p class="small muted" style="margin-top:0">Ein paar Impulse, falls du nicht weißt, wo du anfangen sollst:</p>
      <ul class="prompt-list small muted">
        {prompts.map((p) => <li>{p}</li>)}
      </ul>

      <form id="tagebuch-form">
        <div class="field">
          <label for="eintrag-text">Dein Eintrag von heute</label>
          <textarea id="eintrag-text" name="eintrag-text" rows="6"></textarea>
        </div>
        <button type="submit" class="btn">Eintrag speichern</button>
      </form>
    </div>

    <h2>Bisherige Einträge</h2>
    <p id="keine-eintraege" class="small muted">Noch keine Einträge vorhanden.</p>
    <ul id="eintraege-liste" class="entry-list"></ul>

    <p><a href="/mitarbeiter/selbstfuersorge/" class="btn btn-secondary">← Zurück zur Selbstfürsorge</a></p>
  </div>
</BaseLayout>

<style>
  .article {
    padding-block: 2.5rem 1rem;
  }
  .prompt-list {
    margin: 0 0 1.25rem;
    padding-left: 1.2rem;
  }
  .entry-list {
    list-style: none;
    margin: 1rem 0 2rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .entry {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem 1.2rem;
  }
  .entry-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .entry-text {
    margin: 0;
    white-space: pre-wrap;
  }
</style>

<script>
  const STORAGE_KEY = 'eh-kompass-tagebuch-eintraege';

  interface Eintrag {
    id: string;
    datum: string;
    text: string;
  }

  const form = document.getElementById('tagebuch-form') as HTMLFormElement;
  const textfeld = document.getElementById('eintrag-text') as HTMLTextAreaElement;
  const liste = document.getElementById('eintraege-liste') as HTMLUListElement;
  const keineEintraegeHinweis = document.getElementById('keine-eintraege') as HTMLParagraphElement;

  function ladeEintraege(): Eintrag[] {
    try {
      const roh = localStorage.getItem(STORAGE_KEY);
      return roh ? (JSON.parse(roh) as Eintrag[]) : [];
    } catch {
      return [];
    }
  }

  function speichereEintraege(eintraege: Eintrag[]) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(eintraege));
  }

  function formatiereDatum(iso: string): string {
    return new Date(iso).toLocaleString('de-DE', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    });
  }

  function rendereEintraege() {
    const eintraege = ladeEintraege().sort((a, b) => b.datum.localeCompare(a.datum));
    keineEintraegeHinweis.hidden = eintraege.length > 0;
    liste.innerHTML = eintraege
      .map(
        (e) => `
          <li class="entry" data-id="${e.id}">
            <div class="entry-head">
              <strong class="small">${formatiereDatum(e.datum)}</strong>
              <button type="button" class="btn btn-secondary btn-loeschen" data-id="${e.id}">Löschen</button>
            </div>
            <p class="entry-text">${e.text.replace(/</g, '&lt;')}</p>
          </li>
        `
      )
      .join('');

    liste.querySelectorAll<HTMLButtonElement>('.btn-loeschen').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id;
        speichereEintraege(ladeEintraege().filter((e) => e.id !== id));
        rendereEintraege();
      });
    });
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const text = textfeld.value.trim();
    if (!text) return;

    const neuerEintrag: Eintrag = {
      id: crypto.randomUUID(),
      datum: new Date().toISOString(),
      text,
    };
    speichereEintraege([...ladeEintraege(), neuerEintrag]);
    textfeld.value = '';
    rendereEintraege();
  });

  rendereEintraege();
</script>
