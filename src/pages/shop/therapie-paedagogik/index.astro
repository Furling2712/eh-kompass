---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProduktGrid from '../../../components/ProduktGrid.astro';
import { kategorien, produkte } from '../../../data/shop-produkte';

const kategorie = kategorien.find((k) => k.slug === 'therapie-paedagogik')!;
const kategorieProdukte = produkte.filter((p) => p.kategorieSlug === kategorie.slug);
---

<BaseLayout title={`Shop – ${kategorie.label}`} description={kategorie.beschreibung}>
  <div class="container prose article">
    <a href="/shop/" class="back-link">← Zurück zum Shop</a>
    <h1>{kategorie.label}</h1>
    <p class="lead muted">{kategorie.beschreibung}</p>

    <ProduktGrid produkte={kategorieProdukte} />

    <p><a href="/shop/warenkorb/" class="btn btn-secondary">Zum Warenkorb →</a></p>
  </div>
</BaseLayout>

<style>
  .article {
    padding-block: 2.5rem 1rem;
  }
  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-primary-dark);
    font-weight: 600;
    text-decoration: none;
  }
</style>
