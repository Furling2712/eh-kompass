---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { kategorien, produkte } from '../../data/shop-produkte';
---

<BaseLayout
  title="Shop"
  description="Handgefertigte systemtherapeutische Methoden und Materialien für die Eingliederungshilfe."
>
  <div class="container prose article">
    <h1>Shop</h1>
    <p class="lead muted">
      Handgefertigte systemtherapeutische Materialien für die Eingliederungshilfe – von unserem
      Systemiker, mit Sorgfalt in eigener Werkstatt hergestellt.
    </p>

    <ul class="card-grid kategorie-grid">
      {
        kategorien.map((k) => {
          const anzahl = produkte.filter((p) => p.kategorieSlug === k.slug).length;
          return (
            <li class="card kategorie-card">
              <a href={`/shop/${k.slug}/`} class="card-link">
                <span class="badge">{anzahl} {anzahl === 1 ? 'Produkt' : 'Produkte'}</span>
                <h2>{k.label}</h2>
                <p>{k.beschreibung}</p>
                <span class="btn">Ordner öffnen →</span>
              </a>
            </li>
          );
        })
      }
    </ul>

    <p><a href="/shop/warenkorb/" class="btn btn-secondary">Zum Warenkorb →</a></p>
  </div>
</BaseLayout>

<style>
  .article {
    padding-block: 2.5rem 1rem;
  }
  .kategorie-grid {
    margin-top: 2rem;
  }
  .kategorie-card .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .kategorie-card h2 {
    margin: 0.5rem 0 0.5rem;
  }
  .kategorie-card .btn {
    margin-top: 0.75rem;
    display: inline-block;
  }
</style>
