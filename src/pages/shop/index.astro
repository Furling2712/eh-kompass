---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { produkte } from '../../data/shop-produkte';
---

<BaseLayout
  title="Shop"
  description="Handgefertigte systemtherapeutische Methoden und Materialien für die Eingliederungshilfe."
>
  <div class="container prose article">
    <h1>Shop</h1>
    <p class="lead muted">
      Handgefertigte systemtherapeutische Materialien für die Eingliederungshilfe – von unserem
      Systemiker, mit Sorgfalt in eigener Werkstatt hergestellt.
    </p>

    <ul class="card-grid">
      {
        produkte.map((p) => (
          <li class="card">
            <a href={`/shop/${p.id}/`} class="card-link">
              <img src={p.bild} alt={p.name} class="produkt-bild" />
              <h3>{p.name}</h3>
            </a>
            <p class="small muted" style="margin:-0.5rem 0 0">
              {p.kategorie}
            </p>
            <p>{p.beschreibung}</p>
            <p class="preis">{p.preis.toFixed(2)} €</p>
            <a href={`/shop/${p.id}/`} class="btn">
              Ansehen
            </a>
          </li>
        ))
      }
    </ul>

    <p><a href="/shop/warenkorb/" class="btn btn-secondary">Zum Warenkorb →</a></p>
  </div>
</BaseLayout>

<style>
  .article {
    padding-block: 2.5rem 1rem;
  }
  .card-link {
    text-decoration: none;
    color: inherit;
  }
  .produkt-bild {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius);
    margin-bottom: 0.75rem;
    background: var(--color-surface);
  }
  .preis {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    margin: 0.25rem 0 1rem;
  }
</style>
